# Keep Docker build context small — exclude large/irrelevant directories

# Python environments and caches
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Large test assets
test-images/
output/
debug/
uploads/
models/

# macOS app
mac-app/

# CDK infra (not needed in Lambda image)
infra/

# Web frontend (Phase 3)
web/

# Git
.git/
.gitignore

# Dev files
*.md
.env
secrets.json
journal/
docs/

# Build artifacts
*.egg-info/
dist/
build/
